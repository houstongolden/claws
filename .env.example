CLAWS_PORT=4317
# CLAWS_DEFAULT_VIEW=founder
DASHBOARD_PORT=4318
NEXT_PUBLIC_CLAWS_GATEWAY_URL=http://localhost:4317
CLAWS_GATEWAY_URL=http://localhost:4317
CLAWS_SANDBOX_ENABLED=false

# AI — OpenRouter first when OPENROUTER_API_KEY is set (recommended).
# Optional: AI_GATEWAY_API_KEY (Vercel); only one primary is used — OpenRouter wins if both set.
OPENROUTER_API_KEY=
# AI_MODEL default in code: openai/gpt-5.4 (override if you prefer another OpenRouter id)
# AI_MODEL=openai/gpt-5.4
# Optional OpenRouter headers
# OPENROUTER_HTTP_REFERER=https://yoursite.com
# OPENROUTER_APP_TITLE=Claws

AI_GATEWAY_API_KEY=
# AI_GATEWAY_URL=   # do not use .../v1; empty = https://ai-gateway.vercel.sh/v3/ai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AGENT_BROWSER_NATIVE=1

# Browser automation (optional)
# CLAWS_BROWSER_PROVIDER=agent-browser
# CLAWS_BROWSER_PROVIDER=playwright
# CLAWS_BROWSER_DEFAULT_MODE=background
# CLAWS_BROWSER_DEFAULT_MODE=record-on-complete

# Optional integrations (not required for local boot)
TELEGRAM_BOT_TOKEN=
VERCEL_API_TOKEN=

# V0 Platform API (Hubify Team)
V0_API_KEY=
