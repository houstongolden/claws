CLAWS_PORT=4317
# CLAWS_DEFAULT_VIEW=founder
DASHBOARD_PORT=4318
NEXT_PUBLIC_CLAWS_GATEWAY_URL=http://localhost:4317
CLAWS_GATEWAY_URL=http://localhost:4317
CLAWS_SANDBOX_ENABLED=false

# AI provider routing (priority order)
# 1) AI_GATEWAY_API_KEY (Vercel AI Gateway, preferred)
# 2) OPENAI_API_KEY (direct OpenAI fallback)
# 3) ANTHROPIC_API_KEY (direct Anthropic fallback)
AI_GATEWAY_API_KEY=
AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# AI_MODEL=gpt-4o-mini
AGENT_BROWSER_NATIVE=1


# Browser automation (optional)
# Prefer Agent Browser when set; falls back to Playwright if SDK unavailable.
# CLAWS_BROWSER_PROVIDER=agent-browser
# CLAWS_BROWSER_PROVIDER=playwright
# CLAWS_BROWSER_DEFAULT_MODE=background
# CLAWS_BROWSER_DEFAULT_MODE=record-on-complete

# Optional integrations (not required for local boot)
TELEGRAM_BOT_TOKEN=
VERCEL_API_TOKEN=

# others I added not yet organized 
OPENROUTER_API_KEY=

# V0 Platform API (Hubify Team)
V0_API_KEY=