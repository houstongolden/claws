{
  "name": "@claws/sdk",
  "version": "0.1.0",
  "private": true,
  "description": "Claws SDK — framework-agnostic communication layer for OpenClaw Gateway v3",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/claws-sdk.js",
      "require": "./dist/claws-sdk.cjs"
    },
    "./core": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/claws-sdk.js",
      "require": "./dist/claws-sdk.cjs"
    },
    "./react": {
      "types": "./dist/types/react.d.ts",
      "import": "./dist/claws-sdk-react.js",
      "require": "./dist/claws-sdk-react.cjs"
    },
    "./types": {
      "types": "./dist/types/core/types.d.ts",
      "import": "./dist/claws-sdk.js",
      "require": "./dist/claws-sdk.cjs"
    }
  },
  "main": "./dist/claws-sdk.cjs",
  "module": "./dist/claws-sdk.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist/types",
    "dev": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.3.0",
    "@types/react": "^19.0.0"
  }
}
